AUTOSTREAM_BIND_ADDR=127.0.0.1:8080
AUTOSTREAM_ENV=production
AUTOSTREAM_PUBLIC_URL=https://control.example.com
AUTOSTREAM_DATA_DIR=/var/lib/autostream/control-panel
AUTOSTREAM_WEB_DIR=/usr/share/autostream-control-panel
AUTOSTREAM_TRUSTED_PROXIES=127.0.0.1
AUTOSTREAM_SESSION_SECRET=<CHANGE_ME_64_BYTES>
AUTOSTREAM_SECRET_ENCRYPTION_KEY=<CHANGE_ME_32_BYTES>
AUTOSTREAM_SETUP_TOKEN=<SETUP_TOKEN>
AUTOSTREAM_WEBAUTHN_RP_ID=control.example.com
AUTOSTREAM_WEBAUTHN_RP_NAME=AutoStream Control Panel
AUTOSTREAM_WEBAUTHN_RP_ORIGINS=https://control.example.com
DATABASE_URL=mysql://autostream:<PASSWORD>@tcp(mariadb:3306)/autostream_control_panel?parseTime=true
OBSERVABILITY_TIMEOUT_SEC=5
# Legacy fallback only. New Node Agent dispatch uses per-node runtime tokens
# stored from Node registration config.
SERVICE_CALL_TOKEN=
SERVICE_CALL_TIMEOUT_SEC=5
AUTOSTREAM_YOUTUBE_COMPLETE_RETRY_INTERVAL=60s
# Control Panel-only source. Node registration distributes this to Worker and Encoder config.yml.
AUTOSTREAM_STREAM_INGEST_SIGNING_KEY=<CHANGE_ME_64_BYTES>
AUTOSTREAM_STREAM_INGEST_TOKEN_TTL_MIN=720
AUTOSTREAM_SERVICE_ALLOWED_HOSTS=
AUTOSTREAM_SERVICE_ALLOWED_CIDRS=
AUTOSTREAM_SERVICE_PUBLIC_ALLOWED_HOSTS=
AUTOSTREAM_REQUIRE_SERVICE_PUBLIC_ALLOWED_HOSTS=true
# Optional update notifications shown in the application information page.
# Each service checks its own Kome-Lab GitHub Releases repository by default.
# Set AUTOSTREAM_UPDATE_CHECK_TOKEN for private GitHub release checks.
# A service-specific *_UPDATE_CHECK_URL=off disables only that service check.
# A service-specific *_LATEST_VERSION overrides its network check.
AUTOSTREAM_LATEST_VERSION=
AUTOSTREAM_UPDATE_CHECK_URL=
AUTOSTREAM_WORKER_LATEST_VERSION=
AUTOSTREAM_WORKER_UPDATE_CHECK_URL=
AUTOSTREAM_ENCODER_RECORDER_LATEST_VERSION=
AUTOSTREAM_ENCODER_RECORDER_UPDATE_CHECK_URL=
AUTOSTREAM_DISCORD_BOT_LATEST_VERSION=
AUTOSTREAM_DISCORD_BOT_UPDATE_CHECK_URL=
AUTOSTREAM_OBSERVABILITY_LATEST_VERSION=
AUTOSTREAM_OBSERVABILITY_UPDATE_CHECK_URL=
AUTOSTREAM_UPDATE_CHECK_TOKEN=
TZ=Asia/Tokyo
